# ============================================================
# LarisManis — Konfigurasi Environment
# Salin file ini menjadi ".env" lalu isi nilainya.
# Perintah:  cp .env.example .env
# ============================================================

# ---- SUPABASE (database real-time) — WAJIB ----
# Dapatkan dari: Dashboard Supabase > Project Settings > API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...isi_anon_key_di_sini

# ---- GEMINI AI ----
# Dapatkan gratis dari: https://aistudio.google.com/apikey
#
# MODE LOKAL (development di komputer sendiri):
#   Isi VITE_GEMINI_API_KEY di bawah ini. Aplikasi akan memanggil
#   Google langsung dari browser. Praktis untuk development.
VITE_GEMINI_API_KEY=AIza...isi_api_key_gemini_di_sini

# MODE PRODUKSI (deploy di Vercel):
#   JANGAN isi VITE_GEMINI_API_KEY di Vercel (karena akan terlihat
#   oleh publik). Sebagai gantinya, isi variabel GEMINI_API_KEY
#   (tanpa awalan VITE_) di dashboard Vercel. API key akan disimpan
#   aman di server dan dipanggil lewat proxy /api/gemini.
# GEMINI_API_KEY=AIza...

# ---- MODEL AI (opsional, sudah ada nilai bawaan) ----
# Model gratis yang tersedia: gemini-2.5-flash (bawaan, mendukung foto),
# gemini-2.5-flash-lite (kuota harian lebih besar)
# VITE_GEMINI_MODEL=gemini-2.5-flash
